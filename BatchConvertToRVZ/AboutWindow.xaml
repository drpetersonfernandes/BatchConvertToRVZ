<Window x:Class="BatchConvertToRVZ.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Batch Convert to RVZ"
        Width="600"
        Height="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Logo Section -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15" ToolTip="Application Logo">
            <StackPanel HorizontalAlignment="Center">
                <Image Width="120" Height="120" Source="pack://application:,,,/images/logo.png" />
            </StackPanel>
        </Border>

        <!-- Title & Version Section -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15" ToolTip="Application name and version">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="20" Foreground="{StaticResource HeaderTextBrush}" Text="Batch Convert to RVZ" HorizontalAlignment="Center" />
                <TextBlock Name="AppVersionTextBlock" Margin="0,8,0,0" Text="" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="SemiBold" FontSize="14" ToolTip="Application version" />
            </StackPanel>
        </Border>

        <!-- Description Section -->
        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15" ToolTip="Brief overview of the application purpose">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Text="Description" Margin="0,0,0,10" />
                <TextBlock TextWrapping="Wrap" Text="A utility for batch converting GameCube/Wii ISO images to RVZ format." Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20" />
                <TextBlock Margin="0,10,0,0">
                    <Hyperlink NavigateUri="https://github.com/drpetersonfernandes/BatchConvertToRVZ" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource LinkTextBrush}" TextDecorations="Underline" ToolTip="Visit the project repository">
                        https://github.com/drpetersonfernandes/BatchConvertToRVZ
                    </Hyperlink>
                </TextBlock>
                <TextBlock Margin="0,15,0,0">
                    <Hyperlink NavigateUri="https://www.purelogiccode.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource LinkTextBrush}" TextDecorations="Underline" ToolTip="Visit the official website">
                        https://www.purelogiccode.com
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Acknowledgements Section -->
        <Border Grid.Row="3" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15" ToolTip="Credits and third-party tools used">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Text="Acknowledgements" Margin="0,0,0,10" />
                <TextBlock Margin="0,0,0,8" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="• Uses " />
                    <Hyperlink NavigateUri="https://dolphin-emu.org/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="Bold" TextDecorations="None" ToolTip="Open Dolphin Emulator website">DolphinTool.exe</Hyperlink>
                    <Run Text=" from the Dolphin Emulator project for conversions." />
                </TextBlock>
                <TextBlock Margin="0,0,0,8" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="• Uses " />
                    <Hyperlink NavigateUri="https://github.com/adamhathcock/sharpcompress" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="Bold" TextDecorations="None" ToolTip="Open SharpCompress GitHub repository">SharpCompress</Hyperlink>
                    <Run Text=" for .zip, .7z and .rar archive extraction." />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Close Button Section -->
        <StackPanel Grid.Row="4" HorizontalAlignment="Center">
            <Button Click="CloseButton_Click" Content="Close" Style="{StaticResource ActionButtonStyle}" ToolTip="Close the About window" />
        </StackPanel>
    </Grid>
</Window>

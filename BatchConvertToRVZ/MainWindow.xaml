<Window x:Class="BatchConvertToRVZ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Convert to RVZ"
        Height="850" Width="1200" MinHeight="700" MinWidth="900"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0: Header -->
            <RowDefinition Height="*" />    <!-- 1: Main Content -->
            <RowDefinition Height="Auto" /> <!-- 2: StatusBar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Batch Convert to RVZ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" Margin="0,0,30,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="CheckForUpdatesMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource InfoTextBrush}" ToolTip="Check for application updates">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/update.png" Width="16" Height="16" Margin="0,0,5,0" />
                                <TextBlock Text="Updates" Foreground="{StaticResource ButtonTextDarkBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Click="AboutMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AboutButtonBrush}" ToolTip="View application information and acknowledgements">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/about.png" Width="16" Height="16" Margin="0,0,5,0" />
                                <TextBlock Text="About" Foreground="{StaticResource ButtonTextDarkBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Click="ExitMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource ExitButtonBrush}" ToolTip="Close the application">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/exit.png" Width="16" Height="16" Margin="0,0,5,0" />
                                <TextBlock Text="Exit" Foreground="{StaticResource ButtonTextDarkBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />    <!-- 0: Left Column - Controls & Settings -->
                <ColumnDefinition Width="5" />   <!-- 1: Grid Splitter -->
                <ColumnDefinition Width="*" MinWidth="300" />   <!-- 2: Right Column - Log Viewer -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />      <!-- 0: Main Content -->
                <RowDefinition Height="Auto" />   <!-- 1: Stats Panel -->
                <RowDefinition Height="Auto" />   <!-- 2: Progress Area -->
            </Grid.RowDefinitions>

            <TabControl Grid.Column="0" Grid.Row="0" x:Name="MainTabControl" Background="Transparent" BorderThickness="0" VerticalAlignment="Stretch">
                <TabItem Header="Convert to RVZ" ToolTip="Batch convert GameCube/Wii ISO images to RVZ">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15" VerticalAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Input -->
                                <RowDefinition Height="Auto" /> <!-- Output -->
                                <RowDefinition Height="Auto" /> <!-- Options -->
                                <RowDefinition Height="Auto" /> <!-- Label -->
                                <RowDefinition Height="*" />    <!-- DataGrid -->
                                <RowDefinition Height="Auto" /> <!-- Buttons -->
                                <RowDefinition Height="Auto" /> <!-- Start -->
                            </Grid.RowDefinitions>

                            <!-- Input Folder Selection -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Input Folder:" ToolTip="Select the folder containing ISO/GCM/WBFS/RVZ files to convert" />
                                <TextBox x:Name="InputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The folder containing game files to be converted" />
                                <Button x:Name="BrowseInputButton" Grid.Column="2" Content="Browse..." Click="BrowseInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for the input folder containing game files" />
                            </Grid>

                            <!-- Output Folder Selection -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Output Folder:" ToolTip="Select where the converted RVZ files will be saved" />
                                <TextBox x:Name="OutputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The destination folder for converted RVZ files. This must be different from the input folder." />
                                <Button x:Name="BrowseOutputButton" Grid.Column="2" Content="Browse..." Click="BrowseOutputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for the output folder where converted files will be saved" />
                            </Grid>

                            <!-- Options Grid -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Left Column: General Settings -->
                                <GroupBox Grid.Column="0" Header="General Settings" Margin="0,5,5,10" Padding="10">
                                    <StackPanel>
                                        <CheckBox x:Name="DeleteFilesCheckBox" Content="Delete original files after conversion" Margin="0,5" HorizontalAlignment="Left" ToolTip="WARNING: Permanently deletes source files after successful conversion. Use with caution!" />

                                    </StackPanel>
                                </GroupBox>

                                <!-- Right Column: Compression Settings -->
                                <GroupBox Grid.Column="1" Header="Compression Settings" Margin="5,5,0,10" Padding="10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Method:" VerticalAlignment="Center" ToolTip="Compression algorithm" />
                                            <ComboBox x:Name="CompressionMethodComboBox" Grid.Column="1" VerticalAlignment="Center" SelectedIndex="0" SelectionChanged="CompressionMethodComboBox_SelectionChanged" ToolTip="Compression algorithm used for RVZ files">
                                                <ComboBoxItem Content="zstd (Zstandard)" Tag="zstd" />
                                                <ComboBoxItem Content="zlib" Tag="zlib" />
                                                <ComboBoxItem Content="lzma" Tag="lzma" />
                                                <ComboBoxItem Content="lzma2" Tag="lzma2" />
                                                <ComboBoxItem Content="bzip2" Tag="bzip2" />
                                                <ComboBoxItem Content="lz4" Tag="lz4" />
                                            </ComboBox>
                                        </Grid>

                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="30" />
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Level:" VerticalAlignment="Center" ToolTip="Compression level" />
                                            <Slider x:Name="CompressionLevelSlider" Grid.Column="1" VerticalAlignment="Center" Minimum="1" Maximum="22" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="CompressionLevelSlider_ValueChanged"
                                                    ToolTip="Compression level (higher = better compression but slower)" />
                                            <TextBlock x:Name="CompressionLevelValue" Grid.Column="2" Text="5" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource PrimaryAccentBrush}" ToolTip="Current compression level" />
                                        </Grid>

                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Block Size:" VerticalAlignment="Center" ToolTip="Block size for RVZ container" />
                                            <ComboBox x:Name="BlockSizeComboBox" Grid.Column="1" VerticalAlignment="Center" SelectedIndex="2" ToolTip="Block size for RVZ container (affects compression efficiency)">
                                                <ComboBoxItem Content="32 KB" Tag="32768" />
                                                <ComboBoxItem Content="64 KB" Tag="65536" />
                                                <ComboBoxItem Content="128 KB" Tag="131072" />
                                                <ComboBoxItem Content="256 KB" Tag="262144" />
                                                <ComboBoxItem Content="512 KB" Tag="524288" />
                                                <ComboBoxItem Content="1 MB" Tag="1048576" />
                                                <ComboBoxItem Content="2 MB" Tag="2097152" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>
                            </Grid>

                            <Label Grid.Row="3" Content="Select Files to Convert:" Margin="0,5,0,0" FontWeight="Bold" />
                            <Grid Grid.Row="4" Margin="0,5" VerticalAlignment="Stretch">
                                <DataGrid x:Name="ConversionFilesDataGrid" AutoGenerateColumns="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" SelectionMode="Single" SelectionUnit="CellOrRowHeader"
                                          AllowDrop="True" Drop="ConversionFilesDataGrid_Drop" DragOver="ConversionFilesDataGrid_DragOver" ToolTip="Drag and drop ISO, GCM, WBFS, GCZ, WIA, NKIT.ISO, ZIP, 7Z, or RAR files here">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80" IsThreeState="False" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySize}" Width="130" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button Content="Select All" Click="SelectAllConversion_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" />
                                <Button Content="Deselect All" Click="DeselectAllConversion_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" />
                            </StackPanel>

                            <Button Grid.Row="6" x:Name="StartConversionButton" Content="Start Conversion" Click="StartConversionButton_Click" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Stretch" ToolTip="Begin the batch conversion process" />
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="Verify Integrity of RVZ" ToolTip="Verify the integrity of existing RVZ files">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15" VerticalAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Input -->
                                <RowDefinition Height="Auto" /> <!-- Options -->
                                <RowDefinition Height="Auto" /> <!-- Label -->
                                <RowDefinition Height="*" />    <!-- DataGrid -->
                                <RowDefinition Height="Auto" /> <!-- Buttons -->
                                <RowDefinition Height="Auto" /> <!-- Start -->
                            </Grid.RowDefinitions>

                            <!-- Verify Folder Selection -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Verify Folder:" ToolTip="Select the folder containing RVZ files to verify" />
                                <TextBox x:Name="VerifyFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The folder containing RVZ files to be verified" />
                                <Button x:Name="BrowseVerifyFolderButton" Grid.Column="2" Content="Browse..." Click="BrowseVerifyFolderButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for the folder containing RVZ files to verify" />
                            </Grid>

                            <GroupBox Grid.Row="1" Header="General Settings" Margin="0,5,0,10" Padding="10">
                                <StackPanel>
                                    <CheckBox x:Name="MoveFailedCheckBox" Content="Move failed RVZ files to '_Failed' subfolder" Margin="0,5" HorizontalAlignment="Left" IsChecked="False" ToolTip="Move files that fail verification to a separate folder" />
                                    <CheckBox x:Name="MoveSuccessCheckBox" Content="Move successful RVZ files to '_Success' subfolder" Margin="0,5" HorizontalAlignment="Left" IsChecked="False" ToolTip="Move successfully verified files to a separate folder" />
                                </StackPanel>
                            </GroupBox>

                            <Label Grid.Row="2" Content="Select Files to Verify:" Margin="0,5,0,0" FontWeight="Bold" />
                            <Grid Grid.Row="3" Margin="0,5" VerticalAlignment="Stretch">
                                <DataGrid x:Name="VerificationFilesDataGrid" AutoGenerateColumns="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" SelectionMode="Single" SelectionUnit="CellOrRowHeader"
                                          AllowDrop="True" Drop="VerificationFilesDataGrid_Drop" DragOver="VerificationFilesDataGrid_DragOver" ToolTip="Drag and drop RVZ files here">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80" IsThreeState="False" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySize}" Width="130" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button Content="Select All" Click="SelectAllVerification_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" />
                                <Button Content="Deselect All" Click="DeselectAllVerification_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" />
                            </StackPanel>

                            <Button Grid.Row="5" x:Name="StartVerifyButton" Content="Start Verification" Click="StartVerifyButton_Click" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Stretch" ToolTip="Begin the verification process" />
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="Extract from RVZ" ToolTip="Extract RVZ files">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15" VerticalAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Input -->
                                <RowDefinition Height="Auto" /> <!-- Output -->
                                <RowDefinition Height="Auto" /> <!-- Options -->
                                <RowDefinition Height="Auto" /> <!-- Label -->
                                <RowDefinition Height="*" />    <!-- DataGrid -->
                                <RowDefinition Height="Auto" /> <!-- Buttons -->
                                <RowDefinition Height="Auto" /> <!-- Start -->
                            </Grid.RowDefinitions>

                            <!-- Input Folder Selection -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Input Folder:" ToolTip="Select the folder containing RVZ files to extract" />
                                <TextBox x:Name="ExtractInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The folder containing RVZ files to be extracted" />
                                <Button x:Name="BrowseExtractInputButton" Grid.Column="2" Content="Browse..." Click="BrowseExtractInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for the input folder containing RVZ files" />
                            </Grid>

                            <!-- Output Folder Selection -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Output Folder:" ToolTip="Select where the extracted ISO files will be saved" />
                                <TextBox x:Name="ExtractOutputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The destination folder for extracted ISO files. This must be different from the input folder." />
                                <Button x:Name="BrowseExtractOutputButton" Grid.Column="2" Content="Browse..." Click="BrowseExtractOutputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for the output folder where extracted files will be saved" />
                            </Grid>

                            <GroupBox Grid.Row="2" Header="General Settings" Margin="0,5,0,10" Padding="10">
                                <StackPanel>
                                    <CheckBox x:Name="DeleteExtractedFilesCheckBox" Content="Delete original RVZ files after extraction" Margin="0,5" HorizontalAlignment="Left" ToolTip="WARNING: Permanently deletes source RVZ files after successful extraction. Use with caution!" />
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Label Content="Output Format:" VerticalAlignment="Center" />
                                        <ComboBox x:Name="ExtractOutputFormatComboBox" Width="120" Margin="5,0,0,0" SelectedIndex="0" ToolTip="Select the output format for extracted files">
                                            <ComboBoxItem Content="ISO" />
                                            <ComboBoxItem Content="WBFS" />
                                            <ComboBoxItem Content="GCZ" />
                                            <ComboBoxItem Content="WIA" />
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <Label Grid.Row="3" Content="Select Files to Extract:" Margin="0,5,0,0" FontWeight="Bold" />
                            <Grid Grid.Row="4" Margin="0,5" VerticalAlignment="Stretch">
                                <DataGrid x:Name="ExtractionFilesDataGrid" AutoGenerateColumns="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" SelectionMode="Single" SelectionUnit="CellOrRowHeader"
                                          AllowDrop="True" Drop="ExtractionFilesDataGrid_Drop" DragOver="ExtractionFilesDataGrid_DragOver" ToolTip="Drag and drop RVZ, ZIP, 7Z, or RAR files here">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80" IsThreeState="False" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySize}" Width="130" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button Content="Select All" Click="SelectAllExtraction_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" />
                                <Button Content="Deselect All" Click="DeselectAllExtraction_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" />
                            </StackPanel>

                            <Button Grid.Row="6" x:Name="StartExtractionButton" Content="Start Extraction" Click="StartExtractionButton_Click" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Stretch" ToolTip="Begin the batch extraction process" />
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <GridSplitter x:Name="Splitter" Grid.Column="1" Grid.Row="0" Width="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          Background="{StaticResource BorderBrush}"
                          ShowsPreview="True">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Cursor" Value="SizeWE" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Log Viewer -->
            <Border Grid.Column="2" Grid.Row="0" BorderBrush="{StaticResource TerminalBorderBrush}" BorderThickness="2" CornerRadius="4" Background="{StaticResource TerminalBackgroundBrush}">
                <TextBox x:Name="LogViewer"
                         Style="{StaticResource TerminalLogViewerStyle}"
                         ToolTip="Application activity log" />
            </Border>

            <!-- Stats Panel -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}" ToolTip="Total number of files">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL FILES" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="TotalFilesValue" Text="0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}" ToolTip="Successfully processed files">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="SUCCESS" FontSize="10" Foreground="{StaticResource SuccessTextBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="SuccessValue" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessTextBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}" ToolTip="Failed files">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="FAILED" FontSize="10" Foreground="{StaticResource FailedTextBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="FailedValue" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource FailedTextBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatCard}" ToolTip="Time elapsed">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="ELAPSED" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ProcessingTimeValue" Text="00:00:00" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource StatCard}" ToolTip="Current processing speed">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="SPEED" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="WriteSpeedValue" Text="0.0 MB/s" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Progress Area -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ProgressBar x:Name="FileProgressBar" Grid.Row="1" Height="20" Margin="0,0,0,10" ToolTip="Current file conversion/verification progress" />
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="ProgressBar" Grid.Column="1" Height="20" ToolTip="Overall batch progress (files processed / total files)" VerticalAlignment="Center" />
                    </Grid>
                </Grid>
                <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Click="CancelButton_Click" Style="{StaticResource CancelButtonStyle}" Width="100" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center" ToolTip="Cancel the current operation" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                        <TextBlock x:Name="StatusBarText" Text="Ready" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Application status" />
            </StatusBarItem>
        </StatusBar>

        <!-- Extraction Overlay -->
        <Grid x:Name="ExtractionOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              Style="{StaticResource ExtractionOverlayStyle}"
              Panel.ZIndex="100">
            <Border Style="{StaticResource ExtractionOverlayBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Please wait"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeaderTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />
                    <TextBlock x:Name="ExtractionOverlayText"
                               Text="Extracting archive..."
                               FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="400" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
